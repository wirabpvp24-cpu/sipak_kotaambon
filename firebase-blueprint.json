{
  "entities": {
    "Alumni": {
      "title": "Alumni",
      "description": "Data alumni PAK Kota Ambon",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Nama Lengkap" },
        "gender": { "type": "string", "enum": ["Laki-laki", "Perempuan"] },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "maritalStatus": { "type": "string", "enum": ["Lajang", "Menikah", "Cerai"] },
        "educations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": { "type": "string", "enum": ["DIII", "DIV", "S1", "S2", "S3"] },
              "graduationYear": { "type": "number" },
              "institution": { "type": "string" },
              "major": { "type": "string", "description": "Program Studi" }
            }
          }
        },
        "lastJob": { "type": "string" },
        "address": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "otherSkill": { "type": "string" },
        "isWillingToServe": { "type": "boolean" },
        "serviceInterests": { "type": "array", "items": { "type": "string" } },
        "otherServiceInterest": { "type": "string" },
        "isInKTB": { "type": "boolean" },
        "ktbName": { "type": "string" },
        "ktbLeader": { "type": "string" },
        "isWillingToJoinKTB": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "gender", "email", "phone", "educations", "skills"]
    },
    "Event": {
      "title": "Event",
      "description": "Jadwal kegiatan alumni",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Judul Kegiatan" },
        "theme": { "type": "string", "description": "Tema Kegiatan" },
        "speaker": { "type": "string", "description": "Nama Pembicara" },
        "description": { "type": "string", "description": "Keterangan" },
        "date": { "type": "string", "format": "date", "description": "Tanggal Kegiatan" },
        "time": { "type": "string", "description": "Jam Kegiatan (Format 24 Jam, misal: 14:30)" },
        "timezone": { "type": "string", "enum": ["WIB", "WITA", "WIT"], "description": "Wilayah Waktu" },
        "location": { "type": "string", "description": "Lokasi" },
        "imageUrl": { "type": "string", "description": "URL Gambar Flyer Kegiatan" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "time", "location"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Informasi profil organisasi",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Konten profil (Markdown)" },
        "vision": { "type": "string", "description": "Visi" },
        "mission": { "type": "string", "description": "Misi" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "HomeSettings": {
      "title": "Home Settings",
      "description": "Pengaturan konten halaman beranda",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "welcomeText": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "EventResponse": {
      "title": "Event Response",
      "description": "Kehadiran dan masukan alumni untuk kegiatan",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "alumniId": { "type": "string" },
        "alumniName": { "type": "string" },
        "alumniGender": { "type": "string", "enum": ["Laki-laki", "Perempuan"] },
        "status": { "type": "string", "enum": ["Hadir", "Tidak Hadir"] },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "alumniId", "alumniName", "alumniGender", "status", "createdAt"]
    }
  },
  "firestore": {
    "/alumni/{alumniId}": {
      "schema": "Alumni",
      "description": "Koleksi data alumni"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Koleksi jadwal kegiatan"
    },
    "/event_responses/{responseId}": {
      "schema": "EventResponse",
      "description": "Koleksi kehadiran dan masukan alumni"
    },
    "/settings/profile": {
      "schema": "Profile",
      "description": "Informasi profil organisasi"
    },
    "/settings/home": {
      "schema": "HomeSettings",
      "description": "Konten halaman beranda"
    }
  }
}
