{
  "entities": {
    "Alumni": {
      "title": "Alumni",
      "description": "Data alumni PAK Kota Ambon",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Nama Lengkap" },
        "gender": { "type": "string", "enum": ["Laki-laki", "Perempuan"] },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "maritalStatus": { "type": "string", "enum": ["Lajang", "Menikah", "Cerai"] },
        "educations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": { "type": "string", "enum": ["DIII", "DIV", "S1", "S2", "S3"] },
              "graduationYear": { "type": "number" },
              "institution": { "type": "string" }
            }
          }
        },
        "lastJob": { "type": "string" },
        "address": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "gender", "email", "phone", "educations"]
    },
    "Event": {
      "title": "Event",
      "description": "Jadwal kegiatan alumni",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Judul Kegiatan" },
        "description": { "type": "string", "description": "Keterangan" },
        "date": { "type": "string", "format": "date", "description": "Tanggal Kegiatan" },
        "time": { "type": "string", "description": "Jam Kegiatan" },
        "location": { "type": "string", "description": "Lokasi" },
        "imageUrl": { "type": "string", "description": "URL Gambar Flyer Kegiatan" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "time", "location"]
    }
  },
  "firestore": {
    "/alumni/{alumniId}": {
      "schema": "Alumni",
      "description": "Koleksi data alumni"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Koleksi jadwal kegiatan"
    }
  }
}
